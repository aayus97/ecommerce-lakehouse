# Copy this file to .env for local overrides. Keep real .env files out of Git.

APP_ENV=dev
STORAGE_MODE=local

# Pipeline metadata used in logs and metrics.
PIPELINE_NAME=ecommerce-lakehouse
PIPELINE_RUN_ID=

# Spark local dependency cache. Use a writable local path.
SPARK_IVY_DIR=/tmp/spark-ivy

# Dashboard and orchestration ports.
DASHBOARD_PORT=8501
DAGSTER_PORT=3001

# MinIO or S3-compatible object storage.
# Replace these values in .env or your secret manager for any shared environment.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=local-dev-user
MINIO_ROOT_PASSWORD=local-dev-password

# S3A also honors standard AWS-style credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
